body {
  background-color: beige;
  font-family: Arial, sans-serif;
  text-align: center;
  margin: 0;
  padding: 0;
}

/* Headings */
h1 {
  color: darkblue;
}

/* Sections (clean card look) */
.section1, .section2, .section3, .section4 {
  margin: 20px auto;
  padding: 20px;
  width: 70%;
  border-radius: 10px;
}

/* Section colors */
.section1 {
  background-color: white;
}

.section2 {
  background-color: #f9f9f9;
  color: green;
}

.section3 {
  background-color: #e6f2ff;
  font-family: Georgia;
}

.section4 {
  background-color: white;
}

/* 🔥 BETTER LIST DESIGN (THIS IS THE UPGRADE) */
ol {
  display: inline-block;
  text-align: left;
  padding-left: 20px;
}

/* Make list items look nicer */
ol li {
  margin: 10px 0;
  font-size: 18px;
}

/* Sub-list styling */
ul {
  margin-top: 5px;
  margin-bottom: 10px;
}

/* Links */
a {
  color: darkblue;
  text-decoration: none;
  font-weight: bold;
}

a:hover {
  color: red;
}

